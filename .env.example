# Canonical URL (no trailing slash) — required in production for metadata, JSON-LD, sitemap, Open Graph.
# Domaine définitif prévu : ethann-wantiez-portfolio.fr ou .com
NEXT_PUBLIC_SITE_URL=https://www.ethann-wantiez-portfolio.fr

# Optional — footer & structured data (sameAs)
NEXT_PUBLIC_WEBSITE_URL=
NEXT_PUBLIC_CONTACT_EMAIL=devwtz@gmail.com
NEXT_PUBLIC_PROFILE_URL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Optional — meta verification & social
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_TWITTER_HANDLE=

# Legal pages (France / RGPD) — override defaults from src/lib/legal-config.ts if needed
NEXT_PUBLIC_LEGAL_PUBLISHER_NAME=Ethann Wantiez
NEXT_PUBLIC_LEGAL_FORM=Auto-entrepreneur
NEXT_PUBLIC_LEGAL_ADDRESS=22 rue du Général Pershing, 54400 Longwy, France
NEXT_PUBLIC_LEGAL_SIRET=93366467400019
NEXT_PUBLIC_LEGAL_VAT_NUMBER=TVA non applicable, article 293 B du CGI
NEXT_PUBLIC_LEGAL_PHONE=+33 6 15 83 77 84
NEXT_PUBLIC_HOST_NAME=Vercel Inc.
NEXT_PUBLIC_HOST_ADDRESS=440 N Barranca Avenue #4133, Covina, CA 91723, États-Unis
NEXT_PUBLIC_HOST_PHONE=Support : https://vercel.com/help
# Même adresse que le contact général si vous n’avez pas de DPO dédié
NEXT_PUBLIC_DPO_EMAIL=devwtz@gmail.com

# Formulaire de contact — envoi vers votre boîte (serveur uniquement, ne pas commiter les secrets)
# Gmail : activer l’A2F puis créer un « mot de passe d’application » (compte Google)
CONTACT_MAIL_TO=devwtz@gmail.com
CONTACT_SMTP_USER=devwtz@gmail.com
CONTACT_SMTP_PASS=
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=465
# true = port 465 (SSL) ; pour le port 587 (STARTTLS), mettre CONTACT_SMTP_PORT=587 et CONTACT_SMTP_SECURE=false
CONTACT_SMTP_SECURE=true
# Optionnel — nom affiché comme expéditeur
CONTACT_MAIL_FROM_NAME=Portfolio — Contact
